#!/bin/sh
set -e

if ! command -v pnpm >/dev/null 2>&1; then
  if command -v corepack >/dev/null 2>&1; then
    echo "› corepack enable pnpm"
    corepack enable pnpm >/dev/null 2>&1 || true
  fi
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is not installed. Run 'brew install pnpm' (or enable corepack) before re-running node/install.sh." >&2
  exit 1
fi

{{- if .pnpm_packages }}
echo "Installing global pnpm packages"
while IFS= read -r pkg; do
  [ -z "$pkg" ] && continue
  echo "  pnpm add -g $pkg"
  pnpm add -g "$pkg"
done <<'EOF'
{{- range .pnpm_packages }}
{{ . }}
{{- end }}
EOF
{{- else }}
echo "No pnpm packages defined in chezmoi data; skipping global installs."
{{- end }}
