#!/usr/bin/env bash
#
# Legacy bootstrap helper. Prefer `chezmoi init --apply samejar/dotfiles`.

set -euo pipefail

if ! command -v chezmoi >/dev/null 2>&1; then
  echo "chezmoi is required. Install it first with 'brew install chezmoi'." >&2
  exit 1
fi

DOTFILES_ROOT=$(cd "$(dirname "$0")/.." && pwd -P)

chezmoi init --source "$DOTFILES_ROOT" --apply
