#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

DOTFILES=${DOTFILES:-$HOME/.local/share/chezmoi}
if [ ! -d "$DOTFILES" ]; then
  echo "DOTFILES directory $DOTFILES not found. Run 'chezmoi init --apply samejar/dotfiles' first." >&2
  exit 1
fi
export DOTFILES

cd "$DOTFILES"

# Ensure Homebrew exists
if ! command -v brew >/dev/null 2>&1; then
  "$DOTFILES/homebrew/install.sh" 2>&1 || true
fi

if command -v brew >/dev/null 2>&1; then
  echo "› brew update"
  brew update
  echo "› brew bundle"
  default_brewfile="$HOME/.Brewfile"
  if [ ! -f "$default_brewfile" ] && [ -f "$DOTFILES/.Brewfile" ]; then
    default_brewfile="$DOTFILES/.Brewfile"
  fi
  HOMEBREW_BUNDLE_FILE="${HOMEBREW_BUNDLE_FILE:-$default_brewfile}" brew bundle
  echo "› brew autoremove"
  brew autoremove
  echo "› brew cleanup --prune=30"
  brew cleanup --prune=30
fi

if [ -x "$DOTFILES/scripts/setapp/provision.sh" ]; then
  "$DOTFILES/scripts/setapp/provision.sh"
fi

# find the installers and run them iteratively
find . -name install.sh | while read installer ; do sh -c "${installer}" ; done
