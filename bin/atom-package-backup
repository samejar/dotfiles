#!/bin/sh
#
# Usage: atom-package-backup
#
# Saves a list of your currently installed atom packages to
# $DOTFILES/dot_atom/packages.txt suitable for install
# via atom-package-install

set -e

if [ -z "${DOTFILES:-}" ]; then
  if [ -d "$HOME/.local/share/chezmoi" ]; then
    DOTFILES="$HOME/.local/share/chezmoi"
  else
    DOTFILES="$HOME/.dotfiles"
  fi
fi

apm list --installed --bare > "$DOTFILES/dot_atom/packages.txt"
